{
  "name": "iwallet",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "node": "cd packages/contract && bunx hardhat node",
    "deploy:local": "cd packages/contract && bunx hardhat run scripts/deploy-local.ts",
    "dev:backend": "bun run --cwd packages/backend dev",
    "dev:frontend": "bun run --cwd packages/frontend dev",
    "test": "bunx hardhat test"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^3.1.1",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.3",
    "@types/bun": "latest",
    "@types/node": "^22.8.5",
    "contract": "workspace:*",
    "forge-std": "foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.3.0",
    "viem": "^2.43.0"
  },
  "peerDependencies": {
    "typescript": "~5.8.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1"
  }
}
